---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero Section -->
  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
        Words that actually sound like you
      </h1>
      <p class="mt-6 text-xl sm:text-2xl text-gray-600 max-w-2xl mx-auto">
        I'm Devin, a freelance copywriter who helps brands ditch the jargon and connect with real people.
      </p>
      <div class="mt-10">
        <a
          href="#contact"
          class="inline-block bg-gray-900 text-white px-8 py-4 rounded-lg text-lg font-medium hover:bg-gray-800 transition-colors"
        >
          Let's work together
        </a>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Clear, not clever</h3>
          <p class="text-gray-600">
            Your audience doesn't have time for riddles. I write copy that gets to the point without losing personality.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Your voice, amplified</h3>
          <p class="text-gray-600">
            I don't paste your brand into a template. I listen, learn your tone, and write like you would—if you had the time.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Fast turnarounds</h3>
          <p class="text-gray-600">
            Deadlines don't scare me. Whether it's a landing page or a full website, I deliver quality work on time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondary CTA Section -->
  <section class="bg-gray-900 py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Ready to sound like yourself?
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-xl mx-auto">
        Tell me about your project. No pressure, no weird sales tactics—just a conversation about what you need.
      </p>
      <a
        href="#contact"
        class="inline-block bg-white text-gray-900 px-8 py-4 rounded-lg text-lg font-medium hover:bg-gray-100 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
</Base>
