---
import Base from '../layouts/Base.astro';
---

<Base title="Privacy Policy | Devin Larkin" description="Privacy policy for Devin Larkin's freelance copywriting services.">
  <section class="py-16 px-6 max-w-3xl mx-auto">
    <h1 class="text-4xl font-bold mb-8">Privacy Policy</h1>
    
    <!-- PLACEHOLDER: Review and customize this privacy policy for your specific needs -->
    
    <div class="prose prose-gray max-w-none space-y-6">
      <p class="text-gray-600 italic">Last updated: [Insert Date]</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Information We Collect</h2>
      <p>When you contact us through our website, we may collect personal information such as your name, email address, and any other information you choose to provide in your message.</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">How We Use Your Information</h2>
      <p>We use the information you provide to respond to your inquiries, communicate about potential projects, and improve our services.</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Data Protection</h2>
      <p>We take reasonable measures to protect your personal information from unauthorized access, use, or disclosure.</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Third-Party Services</h2>
      <p>Our website may use third-party services for analytics or functionality. These services may collect information as described in their respective privacy policies.</p>
      
      <h2 class="text-2xl font-semibold mt-8 mb-4">Contact</h2>
      <p>If you have questions about this privacy policy, please contact us through the contact form on our website.</p>
    </div>
    
    <p class="mt-12 p-4 bg-yellow-50 border border-yellow-200 rounded text-yellow-800 text-sm">
      <strong>Note:</strong> This is placeholder content. Please review and customize this privacy policy to accurately reflect your data practices and comply with applicable laws.
    </p>
  </section>
</Base>
