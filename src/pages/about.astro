---
import Base from '../layouts/Base.astro';
---

<Base title="About | Devin Larkin" description="Learn more about Devin Larkin, a freelance copywriter who helps brands find their voice and connect with real people.">
  <!-- About Hero Section -->
  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
        About Me
      </h1>
      <p class="mt-6 text-xl sm:text-2xl text-gray-600 max-w-2xl mx-auto">
        The person behind the words.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-20 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Hi, I'm Devin</h2>
      <div class="prose prose-lg text-gray-600 space-y-6">
        <p>
          I'm a freelance copywriter who believes great writing shouldn't feel like work to read. After years of watching brands struggle to say what they actually mean, I decided to help them cut through the noise.
        </p>
        <p>
          My approach is simple: I listen first. Before I write a single word, I want to understand your business, your audience, and what makes you different. Then I craft copy that sounds like you—just sharper, clearer, and more compelling.
        </p>
      </div>
    </div>
  </section>

  <!-- What I Do Section -->
  <section class="bg-gray-50 py-20 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">What I Do</h2>
      <div class="prose prose-lg text-gray-600 space-y-6">
        <p>
          I specialize in website copy, landing pages, and brand messaging for businesses that want to connect with real people. Whether you're launching something new or refreshing what you've got, I help you find the right words.
        </p>
        <p>
          No jargon. No fluff. Just clear, honest writing that gets results. I work with startups, small businesses, and established brands who are tired of sounding like everyone else.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Work With Me Section -->
  <section class="py-20 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Why Work With Me</h2>
      <div class="prose prose-lg text-gray-600 space-y-6">
        <p>
          I'm not here to churn out generic content. Every project gets my full attention, from the initial conversation to the final polish. I meet deadlines, communicate clearly, and genuinely care about making your words work harder for you.
        </p>
        <p>
          If you're looking for a copywriter who treats your brand like their own, let's talk. I'd love to hear what you're working on.
        </p>
      </div>
      <div class="mt-10">
        <a
          href="/#contact"
          class="inline-block bg-gray-900 text-white px-8 py-4 rounded-lg text-lg font-medium hover:bg-gray-800 transition-colors"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Base>
